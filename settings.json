{
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NAME=$(jq -r '.name')\nDIR=\"$CLAUDE_PROJECT_DIR/.claude/worktrees/$NAME\"\ngit worktree add \"$DIR\" -b \"$NAME\" 2>&1\necho \"$DIR\"\n"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.worktree_path' | xargs git worktree remove --force\n"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on_session_end.sh"
          }
        ]
      }
    ]
  }
}